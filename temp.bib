  url = {https://doi.org/10.1109/ACCESS.2022.3183758},
  keywords = {Autonomous driving, feedback delay, human-vehicle interaction, live streaming, network latency, remote control, remote driving, round trip time, ROS, video streaming},
  abstract = {Remote driving enables human operators to control vehicles from distant locations using real-time video feedback, addressing scenarios where full autonomy is not yet feasible or when human intervention is required. This paper presents the design and evaluation of a remote driving system that integrates real-time video streaming over wireless networks with low-latency control mechanisms.}
}

